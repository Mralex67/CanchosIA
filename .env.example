# Variables de entorno para el despliegue de Cochis IA en Vercel.
# Configurá estas en Vercel bajo: Project Settings > Environment Variables.

# OpenAI API key (https://platform.openai.com/api-keys)
# Asegurate de tener acceso a gpt-image-1 para generación de imágenes.
OPENAI_API_KEY=sk-...

# URL de base de datos PostgreSQL (recomendado: Neon https://neon.tech – plan gratuito)
# Usá la "Pooled connection" string (termina en -pooler...).
# Ejemplo: postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Opcional: modelo de chat (por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Opcional: modelo de imagen (por defecto gpt-image-1)
# OPENAI_IMAGE_MODEL=gpt-image-1
